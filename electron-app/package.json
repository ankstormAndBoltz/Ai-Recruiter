{
  "name": "ai-recruiter",
  "version": "2.0.0",
  "description": "AI-powered Candidate Ranking System — Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --win",
    "dist:portable": "electron-builder --win portable"
  },
  "keywords": [
    "ai",
    "recruiter",
    "ranking",
    "ml"
  ],
  "author": "ankstormAndBoltz",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ankstorm.airecruiter",
    "productName": "AI Recruiter",
    "copyright": "Copyright © 2026 ankstormAndBoltz",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "package.json",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!data/**",
          "!storage/**"
        ]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Recruiter"
    },
    "portable": {
      "artifactName": "AI-Recruiter-Portable.exe"
    }
  }
}
